{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-organvm.github.io/schema-definitions/uaks-text-atom.schema.json",
  "title": "UAKS TextAtom",
  "description": "Schema for text-domain atoms produced by the UAKS Text Refinery. A TextAtom is a self-contained unit of human-language meaning with full provenance, entity links, and validation state. Derived from UAKS v1 Architecture Specification sections 4, 11.1, and 16.",
  "type": "object",
  "required": ["atomId", "atomFamily", "atomClass", "content", "contentHash", "sourceRef", "validationState", "createdAt"],
  "properties": {
    "atomId": {
      "type": "string",
      "description": "Unique content-addressed identifier for this atom.",
      "pattern": "^ta_[a-zA-Z0-9_-]+$"
    },
    "atomFamily": {
      "type": "string",
      "const": "text",
      "description": "Always 'text' for TextAtom instances."
    },
    "atomClass": {
      "type": "string",
      "description": "Semantic classification of the text atom content.",
      "enum": [
        "claim",
        "definition",
        "requirement",
        "policy",
        "observation",
        "question",
        "instruction",
        "narrative",
        "evidence",
        "annotation",
        "summary",
        "hypothesis"
      ]
    },
    "textKind": {
      "type": "string",
      "description": "The genre or register of the text.",
      "enum": [
        "technical",
        "academic",
        "conversational",
        "legal",
        "editorial",
        "creative",
        "operational"
      ]
    },
    "content": {
      "type": "string",
      "description": "The distilled, self-contained text content of this atom.",
      "minLength": 1
    },
    "contentHash": {
      "type": "string",
      "description": "SHA-256 hash of the content field for deduplication and integrity.",
      "pattern": "^[a-f0-9]{64}$"
    },
    "sourceRef": {
      "type": "string",
      "description": "Reference to the source object this atom was derived from."
    },
    "sourceSpan": {
      "type": "object",
      "description": "Location within the source where this atom originates.",
      "properties": {
        "startOffset": { "type": "integer", "minimum": 0 },
        "endOffset": { "type": "integer", "minimum": 0 },
        "startLine": { "type": ["integer", "null"] },
        "endLine": { "type": ["integer", "null"] }
      }
    },
    "entities": {
      "type": "array",
      "description": "Entity references extracted from this atom.",
      "items": {
        "type": "object",
        "required": ["entityId", "entityType", "mention"],
        "properties": {
          "entityId": { "type": "string" },
          "entityType": {
            "type": "string",
            "enum": ["person", "organization", "concept", "tool", "repo", "organ", "location", "event"]
          },
          "mention": { "type": "string" }
        }
      },
      "default": []
    },
    "relations": {
      "type": "array",
      "description": "Typed edges connecting this atom to other atoms or entities.",
      "items": {
        "type": "object",
        "required": ["relationType", "targetRef"],
        "properties": {
          "relationType": {
            "type": "string",
            "enum": [
              "SUPPORTS",
              "CONTRADICTS",
              "SUPERSEDES",
              "DERIVES_FROM",
              "EVIDENCE_FOR",
              "DEPENDS_ON",
              "RELATED_TO",
              "IMPLEMENTS",
              "REFINES"
            ]
          },
          "targetRef": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      },
      "default": []
    },
    "validationState": {
      "type": "string",
      "description": "Current governance state of this atom.",
      "enum": ["DRAFT", "DISTILLED", "REVIEWED", "VERIFIED", "DEPRECATED", "DISPUTED"]
    },
    "temporalCues": {
      "type": "object",
      "description": "Temporal metadata extracted from or assigned to this atom.",
      "properties": {
        "effectiveFrom": { "type": ["string", "null"], "format": "date-time" },
        "effectiveUntil": { "type": ["string", "null"], "format": "date-time" },
        "mentionedDate": { "type": ["string", "null"] }
      }
    },
    "provenance": {
      "type": "object",
      "description": "Transformation lineage for this atom.",
      "properties": {
        "refineryVersion": { "type": "string" },
        "refineryStage": { "type": "string" },
        "transformedAt": { "type": "string", "format": "date-time" },
        "parentAtomId": { "type": ["string", "null"] }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of atom creation."
    },
    "updatedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp of last metadata update (content is immutable)."
    }
  },
  "additionalProperties": false
}
