{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meta-organvm.github.io/schema-definitions/system-organism.schema.json",
  "title": "System Organism",
  "description": "Schema for system-organism.json — unified hierarchical snapshot of the eight-organ system.",
  "type": "object",
  "required": ["total_repos", "sys_pct", "organs", "generated"],
  "properties": {
    "total_repos": { "type": "integer", "minimum": 0 },
    "sys_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
    "total_promo_ready": { "type": "integer", "minimum": 0 },
    "total_stale": { "type": "integer", "minimum": 0 },
    "profiles": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "promo_distribution": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "languages": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "gate_stats": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate_stats_entry" }
    },
    "total_discrepancies": { "type": "integer", "minimum": 0 },
    "organs": {
      "type": "array",
      "items": { "$ref": "#/$defs/organ" }
    },
    "omega": {
      "oneOf": [
        { "type": "object" },
        { "type": "null" }
      ]
    },
    "generated": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "gate_stats_entry": {
      "type": "object",
      "required": ["name", "applicable", "passed", "failed", "rate"],
      "properties": {
        "name": { "type": "string" },
        "applicable": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "rate": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "organ": {
      "type": "object",
      "required": ["organ_id", "organ_name", "count", "repos"],
      "properties": {
        "organ_id": { "type": "string" },
        "organ_name": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 },
        "avg_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "promo_ready": { "type": "integer", "minimum": 0 },
        "stale": { "type": "integer", "minimum": 0 },
        "repos": {
          "type": "array",
          "items": { "$ref": "#/$defs/repo" }
        }
      }
    },
    "repo": {
      "type": "object",
      "required": ["repo", "organ", "organ_name"],
      "properties": {
        "repo": { "type": "string" },
        "organ": { "type": "string" },
        "organ_name": { "type": "string" },
        "org": { "type": "string" },
        "tier": { "type": "string" },
        "impl": { "type": "string" },
        "promo": { "type": "string" },
        "profile": { "type": "string" },
        "primary_lang": { "type": "string" },
        "pct": { "type": "integer", "minimum": 0, "maximum": 100 },
        "score": { "type": "integer", "minimum": 0 },
        "max_score": { "type": "integer", "minimum": 0 },
        "promo_ready": { "type": "boolean" },
        "is_stale": { "type": "boolean" },
        "stale_days": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "null" }
          ]
        },
        "next_promo": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "blockers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next_actions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "gates": {
          "type": "array",
          "items": { "$ref": "#/$defs/gate" }
        },
        "discrepancies": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "gate": {
      "type": "object",
      "required": ["name", "applicable", "passed"],
      "properties": {
        "name": { "type": "string" },
        "applicable": { "type": "boolean" },
        "passed": { "type": "boolean" },
        "detail": { "type": "string" }
      }
    }
  }
}
