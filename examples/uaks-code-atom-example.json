  "content": "def ingest_file(self, filepath: str) -> IntakeSource:\n    path = Path(filepath)\n    if not path.exists():\n        raise FileNotFoundError(f\"File not found: {filepath}\")\n    content = path.read_text(encoding=\"utf-8\")\n    atom_hash = hashlib.sha256(content.encode()).hexdigest()[:16]\n    return IntakeSource(id=f\"file_{atom_hash}\", source_type=\"file\", path=str(path), content=content, hash=atom_hash)",
